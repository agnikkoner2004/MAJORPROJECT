<% layout('layouts/boilerplate') %>

<h2 class="mb-4">Explore Experiences</h2>

<% for(let category in listingsByCategory){ %>

<h4 class="mt-4"><%= category %></h4>

<div class="row">

<% listingsByCategory[category].forEach(listing => { %>

<div class="col-md-3 mb-3">

<a href="/listings/<%= listing._id %>" class="listing-link">

<div class="card">

<img src="<%= listing.image.url %>" class="card-img-top" style="height:200px; object-fit:cover;">

<div class="card-body">

<b><%= listing.title %></b>

<p>₹ <%= listing.price.toLocaleString("en-IN") %> / night</p>

</div>

</div>

</a>

</div>

<% }) %>

</div>

<% } %>
