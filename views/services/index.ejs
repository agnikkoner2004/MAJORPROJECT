<% layout('layouts/boilerplate') %>

<style>

.services-header{
	text-align:center;
	margin:30px 0;
}

.service-card{
	border:none;
	border-radius:15px;
	overflow:hidden;
	transition:0.3s ease;
	box-shadow:0 4px 15px rgba(0,0,0,0.1);
}

.service-card:hover{
	transform:translateY(-8px);
	box-shadow:0 8px 25px rgba(0,0,0,0.2);
}

.service-img{
	height:250px;
	object-fit:cover;
}

.service-overlay{
	position:absolute;
	bottom:0;
	background:linear-gradient(transparent, rgba(0,0,0,0.8));
	color:white;
	width:100%;
	padding:20px;
}

.service-icon{
	font-size:24px;
	margin-bottom:8px;
}

</style>


<div class="container">

	<div class="services-header">
		<h2>Premium Services</h2>
		<p class="text-muted">Enhance your Stayclave experience</p>
	</div>

	<div class="row g-4">

		<!-- SPA -->
		<div class="col-md-4">
			<div class="card service-card position-relative">

				<img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?q=80&w=800"
				class="service-img">

				<div class="service-overlay">
					<i class="fa-solid fa-spa service-icon"></i>
					<h4>Spa & Wellness</h4>
					<p>Relax with professional massage and spa therapy.</p>
				</div>

			</div>
		</div>


		<!-- CHEF -->
		<div class="col-md-4">
			<div class="card service-card position-relative">

				<img src="https://images.unsplash.com/photo-1556910103-1c02745aae4d?q=80&w=800"
				class="service-img">

				<div class="service-overlay">
					<i class="fa-solid fa-utensils service-icon"></i>
					<h4>Private Chef</h4>
					<p>Enjoy meals prepared by expert chefs.</p>
				</div>

			</div>
		</div>


		<!-- ACTIVITY -->
		<div class="col-md-4">
			<div class="card service-card position-relative">

				<img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?q=80&w=800"
				class="service-img">

				<div class="service-overlay">
					<i class="fa-solid fa-person-hiking service-icon"></i>
					<h4>Activities</h4>
					<p>Experience trekking, water sports and adventures.</p>
				</div>

			</div>
		</div>

	</div>

</div>
